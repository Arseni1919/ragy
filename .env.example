# ==========================================
# RAGY Configuration Template
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# REQUIRED API Keys
# ==========================================

# Tavily API Key (REQUIRED)
# Get your free API key at: https://tavily.com/
TAVILY_API_KEY="your-tavily-api-key-here"

# ==========================================
# OPTIONAL API Keys
# ==========================================

# Gemini API Key (optional, for LLM features)
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Hugging Face Token (optional, for private models)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=""

# ==========================================
# Embedding Configuration
# ==========================================

# Hugging Face embedding model
# Default: all-MiniLM-L6-v2 (384 dimensions, ~80MB)
# Alternative: google/embeddinggemma-300m (768 dimensions, ~600MB)
HF_EMB_MODEL="all-MiniLM-L6-v2"

# Ollama embedding model (if using Ollama instead)
OLLAMA_EMB_MODEL="nomic-embed-text"

# ==========================================
# Database & Storage
# ==========================================

# Vector database provider
# Options: "zvec" (default), "chromadb"
# zvec: High-performance C++ vector database (recommended)
# chromadb: Python-based vector database (fallback option)
DB_PROVIDER="zvec"

# Vector database path
DB_PATH="./ragy_db"

# Jobs database path (SQLite)
JOBS_DB_PATH="./ragy_jobs.db"

# ==========================================
# Performance
# ==========================================

# Maximum concurrent indexing operations
# Higher = faster but more API calls and memory usage
RAGY_MAX_CONCURRENT=3

# ==========================================
# API Server
# ==========================================

# API server host
API_HOST="0.0.0.0"

# API server port
API_PORT=8000

# ==========================================
# Background Scheduler
# ==========================================

# Enable automatic daily updates
SCHEDULER_ENABLED=true

# Hour for daily updates (0-23, UTC)
SCHEDULER_HOUR=2

# Timezone for scheduler
SCHEDULER_TIMEZONE="UTC"

# ==========================================
# LLM Configuration (Optional)
# ==========================================

# LLM model for RAG conversations
LLM_MODEL="gemini/gemini-2.5-flash-lite"
